# RapidAPI (existing)
RAPIDAPI_KEY=
# Or use this if your frontend already references the VITE-prefixed key
VITE_RAPIDAPI_KEY=

# MySQL sync (new)
# Optional: point UI MySQL actions to standalone API host.
# Local example: http://localhost:4001
# Production example: https://NewsAPI.YubTub.club
VITE_NEWS_API_BASE_URL=http://127.0.0.1:4001

# Legacy local cache server MySQL vars (only needed if using sb-admin-react/server directly)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
