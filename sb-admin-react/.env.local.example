# RapidAPI (existing)
RAPIDAPI_KEY=
# Or use this if your frontend already references the VITE-prefixed key
VITE_RAPIDAPI_KEY=

# Optional local override. The default is set in .env.development.
VITE_NEWS_API_BASE_URL=https://localhost:7125

# Legacy local cache server MySQL vars (only needed if using sb-admin-react/server directly)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
